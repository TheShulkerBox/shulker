from ../food import Food

class Rations(Food):
    """Quick healing food that can be eaten quickly in battle."""

    item_model = "dried_kelp"
    item_name = "Rations"
    enchantment_glint_override = true
    consumable = {
        consume_seconds: 0.8,
        on_consume_effects: [
            {
                type: "apply_effects",
                effects: [
                    {
                        id: "regeneration",
                        amplifier: 3,
                        duration: 3 * 20,
                    }
                ]
            }
        ]
    }