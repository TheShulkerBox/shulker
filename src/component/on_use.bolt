from typing import Literal, Any, Annotated
from dataclasses import field
from nbtlib.tag import Byte

from component:type import Component
from item:type import ItemType
from lib:errors import CustomComponentError
from lib:helpers import deep_merge_dicts
from server:services/playerdb import PlayerDB
from server:core import ROOT_ADVANCEMENT


AnimationLiteral = Annotated[
    Literal["none"]
    | Literal["eat"]
    | Literal["drink"]
    | Literal["block"]
    | Literal["bow"]
    | Literal["trident"]
    | Literal["spyglass"]
    | Literal["toot_horn"]
    | Literal["brush"]
    | Literal["spear"],
    "Right click animations"
]

