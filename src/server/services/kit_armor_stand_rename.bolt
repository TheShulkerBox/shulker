function admin:kit_armor_stand_rename:
    execute as @e[type=armor_stand,tag=KitStand,name="Kit Archer"] run data modify entity @s CustomName set value archer
    execute as @e[type=armor_stand,tag=KitStand,name="Kit Headsman"] run data modify entity @s CustomName set value headsman
