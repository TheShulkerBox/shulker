#> Adds the self tag and automatically removes it

from collections import defaultdict
from contextlib import contextmanager
from itertools import count

from ./helpers import path_to_string

COUNTERS = defaultdict(count)

@contextmanager
def tag_self() -> str:
    path_as_tag = path_to_string(~/)
    suffix = next(COUNTERS[path_as_tag])
    self_tag = f"player.self.{path_as_tag}_{suffix}"
    tag @s add self_tag
    yield self_tag
    tag @s remove self_tag
