from lib:inventory_management import generate_loot_table, hotbar_with_slots_modify


def apply_modifier(pool: dict[str, Any], slot: str) -> dict[str, Any]:
    pool["entries"][0]["children"][1]["functions"] = [
        {
            "function": "minecraft:set_item",
            "item": "minecraft:stick"
        },
        {
            "function": "minecraft:set_components",
            "components": {
                "item_name": "<< DISABLED ITEM >>",
                "item_model": "barrier"
            }
        },
        {
            "function": "minecraft:set_contents",
            "component": "minecraft:bundle_contents",
            "entries": [
                {
                    "type": "minecraft:slots",
                    "slot_source": {
                        "type": "minecraft:slot_range",
                        "source": "this",
                        "slots": slot
                    }
                }
            ]
        }
    ]

    if "armor" in slot:
        pool["entries"][0]["children"][1]["functions"][1]["components"]["equippable"] = {
            "slot": slot.replace("armor.", ""),
            "equip_sound": {"sound_id": ""}
        }

    return pool

loot_table ./bundlify {"pools": generate_loot_table(all=True, modifier=apply_modifier)}

function ./bundlify/apply:
    loot replace entity @s container.0 loot {
        pools: [
            {
                rolls: 1,
                entries: [
                    { type: "loot_table", value: (./bundlify) }
                ]
            }
        ]
    }


def undo_modifier(pool: dict[str, Any], slot: str) -> dict[str, Any]:
    pool["entries"][0]["children"][1] = {
        "type": "minecraft:slots",
        "slot_source": {
            "type": "minecraft:contents",
            "slot_source": {
                "type": "minecraft:slot_range",
                "source": "this",
                "slots": slot
            },
            "component": "minecraft:bundle_contents"
        }
    }
    return pool

loot_table ./bundlify_undo {"pools": generate_loot_table(all=True, modifier=undo_modifier)}

function ./bundlify/undo:
    loot replace entity @s container.0 loot {
        pools: [
            {
                rolls: 1,
                entries: [
                    { type: "loot_table", value: (./bundlify_undo) }
                ]
            }
        ]
    }
