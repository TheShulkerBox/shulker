class TestingFood(KitItem):
    id = "suspicious_stew"
    item_name = "Component Test: Always Edible"
    lore = "always_edible with food nutrition and saturation"
    always_edible = true
    food = {
        nutrition: 4,
        saturation: 5.6,
    }


class TestingPotion(KitItem):
    id = "potion"
