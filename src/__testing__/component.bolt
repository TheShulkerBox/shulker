from item:base import KitItem

def _component_callback(component: str, phase: str):
    path = ./callbacks
    path = f"{path}/{component}/{phase}"

    function path:
        tellraw @s f"[component test] {component}: {phase}"

    return path


class TestingWeapon(KitItem):
    id = "iron_sword"
    item_name = "Component Test: Weapon Suite"
    lore = [
        "melee, left_click, two_handed, strike, and kill",
        "Exercises callback and combat subcomponents.",
    ]
    melee = {
        damage: 6,
        knockback: 1.25,
        crit: 2,
        weight: "heavy",
    }
    two_handed = {
        callback: _component_callback("two_handed", "callback"),
    }
    strike = {
        attacker: _component_callback("strike", "attacker"),
    }
    kill = {
        victim: _component_callback("kill", "victim"),
    }


class TestingUsing(KitItem):
    id = "iron_ingot"
    item_model = "spyglass"
    item_name = "Component Test: Using"
    lore = "using start, during, end, cooldown, animation, and sound"
    using = {
        start: _component_callback("using", "start"),
        during: _component_callback("using", "during"),
        end: _component_callback("using", "end"),
        animation: "spyglass",
        sound: "minecraft:item.spyglass.use",
    }
    left_click = {
        callback: _component_callback("using", "left_click")
    }


class TestingSneaking(KitItem):
    id = "leather_boots"
    item_name = "Component Test: Sneaking"
    lore = "sneaking start, during, and end"
    dyed_color = "#2c8f6b"
    sneaking = {
        start: _component_callback("sneaking", "start"),
        during: _component_callback("sneaking", "during"),
        end: _component_callback("sneaking", "end"),
        slot: "armor.feet"
    }


class TestingUseable(KitItem):
    id = "iron_ingot"
    item_model = "honey_bottle"
    item_name = "Component Test: Useable"
    lore = "useable callback, infinite, delay, cooldown, sound, and effects"
    useable = {
        callback: _component_callback("useable", "callback"),
        infinite: true,
        delay: 0.4,
        cooldown: 2.25,
        cooldown_group: "component_testing:useable",
        animation: "drink",
        sound: "minecraft:item.honey_bottle.drink",
        on_use_effects: [
            {
                type: "apply_effects",
                effects: [
                    {
                        id: "speed",
                        amplifier: 0,
                        duration: 3 * 20,
                    }
                ],
            }
        ],
    }


class TestingBow(KitItem):
    id = "bow"
    item_name = "Component Test: Bow"
    lore = "bow nock, charging, charged, unnock, fire, and hit"
    bow = {
        nock: _component_callback("bow", "nock"),
        charging: _component_callback("bow", "charging"),
        charged: _component_callback("bow", "charged"),
        unnock: _component_callback("bow", "unnock"),
        fire: ./fire,
        hit: ./hit,
    }


function ./fire:
    execute on owner run tellraw @s hit
    tellraw @a "i am an arrow"

function ./hit:
    tellraw @s "u were hit by a warbow"
    execute on attacker run tellraw @s "you hit the target"


class TestingTicking(KitItem):
    id = "clock"
    item_name = "Component Test: Ticking"
    lore = "ticking callback and period"
    ticking = [
        {
            callback: _component_callback("ticking", "2s"),
            period: "2s",
        },
        {
            callback: _component_callback("ticking", "5s"),
            period: "5s",
        }
    ]


class TestingArmor(KitItem):
    id = "leather_chestplate"
    item_name = "Component Test: Armor"
    lore = "armor value, toughness, knockback resistance, speed, and dyed_color"
    dyed_color = "#7f29c6"
    armor = {
        value: 4,
        toughness: 1.5,
        knockback_resistance: 0.1,
        speed: 0.02,
    }


class TestingFood(KitItem):
    id = "suspicious_stew"
    item_name = "Component Test: Always Edible"
    lore = "always_edible with food nutrition and saturation"
    always_edible = true
    food = {
        nutrition: 4,
        saturation: 5.6,
    }


class TestingPotion(KitItem):
    id = "potion"
    item_name = "Component Test: Potion Transformer"
    lore = [
        "potion_contents custom_color transformer",
        "also validates lore list transformation.",
    ]
    potion_contents = {
        custom_color: "#750303",
        custom_effects: [
            {
                id: "minecraft:glowing",
                amplifier: 0,
                duration: 2 * 20,
                show_particles: false,
            }
        ],
    }



THROWABLE_CHARGE_TIME = 1.0


class TestingThrowable(KitItem):
    id = "cobweb"
    item_name = "Component Test: Throwable"
    lore = "throwable item with charge and throw mechanics"
    throwable = {
        start: _component_callback("throwable", "start"),
        during: _component_callback("throwable", "during"),
        end: ./on_throw,
        charge_time: THROWABLE_CHARGE_TIME,
        minimum_charge_time: 0.5,
        charge_curve: "Linear",
        throw_power: 0.3,
        charge_power_ratio: 1.0,
    }


function ./on_throw:
    execute on origin run tellraw @s "[component test] throwable: end"


