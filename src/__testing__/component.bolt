function ./give_all:
    give @s TestingWeapon
    give @s TestingUsing
    give @s TestingSneaking
    give @s TestingUseable
    give @s TestingBow
    give @s TestingTicking
    give @s TestingArmor
    give @s TestingFood
    give @s TestingPotion
    # give @s TestingDroppable
    # give @s TestingResupply
    # give @s TestingItemEnchant
    give @s arrow 64
    give @s TestingThrowable
