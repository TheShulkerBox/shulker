from item:base import KitItem
from lib:motion import apply_motion_vector

from server:core import SERVER_TICK

class Dart(KitItem):
    id = "arrow"
    item_model = "stone"
    item_name = "taco sauce 2 deluxe"
    useable = {callback: ./dart_on_use, infinite: true, cooldown: 0.2}


function ./dart_on_use:
    apply_motion_vector([0.0, 1.5, 2.0])
    # say i've used za dart


class PoisonDart(KitItem):
    id = "arrow"
    item_model = "poisonous_potato"
    item_name = "poison taco sauce 3 deluxe"
    useable = {callback: ./poison_dart_on_use, infinite: true, cooldown: 0.5}


function ./poison_dart_on_use:
    STORAGE.temp.vector = [0] * 3
    for i in range(3):
        store result storage shulker:temp vector[i] double 0.01 random value -500..500
    apply_motion_vector(STORAGE.temp.vector)


def tester(component: str, phase: str):
    path = ./engineer_pickaxe
    path = f"{path}/{component}/{phase}"

    function path:
        say f">> {component}: {phase}"

    return path


class EngineerPickaxe(KitItem):
    id = "iron_pickaxe"
    item_name = "Engineer's Pickaxe"
    melee = {damage: 4, speed: 1.6, crit: 3}
    ticking = [{callback: ./engineer_pickaxe_tick}]
    sneaking = {
        start: tester("sneaking", "start"),
        during: tester("sneaking", "during"),
        end: tester("sneaking", "end"),
    }
    using = {
        start: tester("using", "start"),
        during: tester("using", "during"),
        end: tester("using", "end"),
    }
    two_handed = {}

function ./engineer_pickaxe_tick:
    particle minecraft:witch ~ ~ ~ 0.5 0.5 0.5 0 1 normal


